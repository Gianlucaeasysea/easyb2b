# ============================================================
# EASYB2B — Variabili d'ambiente
# Copia questo file in .env.local e compila i valori
# MAI committare .env.local su git
# ============================================================

# ---- SUPABASE ----
# Trovate in: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# ---- GOOGLE OAUTH (Gmail Integration) ----
# Trovate in: Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ---- SERVIZI EDGE FUNCTIONS (solo per chiamate server-to-server) ----
# Genera una stringa casuale sicura (min 32 caratteri)
# Esempio: openssl rand -hex 32
SERVICE_API_KEY=your-secure-random-service-api-key-minimum-32-chars

# ---- ANALYTICS (opzionale) ----
# Google Analytics - trovato in: GA4 > Admin > Data Streams
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---- AMBIENTE ----
# 'development' o 'production'
NODE_ENV=development
